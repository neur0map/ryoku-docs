{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ryoku",
  "description": "Ryoku is a hand-built Arch Linux distribution: a cohesive Hyprland desktop, a guided installer, and a reproducible single-source system. An opinionated, pre-riced daily driver and Omarchy alternative on Arch + Hyprland, with the ryoku CLI, wallpaper-driven theming, and an opt-in CachyOS kernel.",
  "colors": {
    "primary": "#e2342a",
    "light": "#ef5b50",
    "dark": "#e2342a"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Fraunces"
    },
    "body": {
      "family": "Space Grotesk"
    }
  },
  "background": {
    "color": {
      "dark": "#100d08"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "favicon": "/assets/brand/logo.svg",
  "logo": {
    "light": "/assets/brand/light.png",
    "dark": "/assets/brand/dark.png"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "canonical": "https://docs.ryoku.dev",
      "description": "Ryoku documentation: install, convert, configure, and run the Ryoku Arch Linux Hyprland desktop, an Omarchy alternative.",
      "keywords": "Ryoku, Ryoku Linux, Arch Linux, Hyprland, Omarchy, Omarchy alternative, Quickshell, riced Arch desktop, ryoku CLI, CachyOS, Wayland",
      "og:site_name": "Ryoku Docs",
      "og:title": "Ryoku documentation",
      "og:image": "https://ryoku.dev/social-card.jpg",
      "twitter:card": "summary_large_image",
      "twitter:image": "https://ryoku.dev/social-card.jpg"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/neur0map/ryoku-arch"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/neur0map/ryoku-arch",
      "website": "https://ryoku.dev"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Manual",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "docs/install",
              "docs/dual-boot",
              "docs/convert",
              "docs/first-boot"
            ]
          },
          {
            "group": "The desktop",
            "pages": [
              "docs/tour",
              "docs/navigation",
              "docs/keybindings",
              "docs/settings"
            ]
          },
          {
            "group": "Apps & theming",
            "pages": [
              "docs/apps",
              "docs/theming"
            ]
          },
          {
            "group": "Extras & plugins",
            "pages": [
              "docs/extras",
              "docs/plugins"
            ]
          },
          {
            "group": "Control & config",
            "pages": [
              "docs/cli",
              "docs/customize",
              "docs/hardware",
              "docs/kernels"
            ]
          },
          {
            "group": "Maintenance & help",
            "pages": [
              "docs/updates",
              "docs/troubleshoot",
              "docs/faq"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "docs/rashin",
              "docs/security"
            ]
          }
        ]
      },
      {
        "tab": "Contribute",
        "groups": [
          {
            "group": "Project",
            "pages": [
              "docs/vision",
              "docs/omarchy-heritage",
              "docs/maintenance"
            ]
          },
          {

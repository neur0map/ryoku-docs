{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ryoku",
  "colors": {
    "primary": "#e2342a",
    "light": "#ef5b50",
    "dark": "#e2342a"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Fraunces"
    },
    "body": {
      "family": "Space Grotesk"
    }
  },
  "background": {
    "color": {
      "dark": "#100d08"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "favicon": "/assets/brand/logo.svg",
  "logo": {
    "light": "/assets/brand/light.png",
    "dark": "/assets/brand/dark.png"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.ryoku.dev"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/neur0map/ryoku-arch"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/neur0map/ryoku-arch",
      "website": "https://ryoku.dev"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Manual",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "docs/install",
              "docs/convert",
              "docs/first-boot"
            ]
          },
          {
            "group": "The desktop",
            "pages": [
              "docs/tour",
              "docs/navigation",
              "docs/keybindings",
              "docs/settings"
            ]
          },
          {
            "group": "Apps & theming",
            "pages": [
              "docs/apps",
              "docs/theming"
            ]
          },
          {
            "group": "Extras & plugins",
            "pages": [
              "docs/extras",
              "docs/plugins"
            ]
          },
          {
            "group": "Control & config",
            "pages": [
              "docs/cli",
              "docs/customize",
              "docs/hardware",
              "docs/kernels"
            ]
          },
          {
            "group": "Maintenance & help",
            "pages": [
              "docs/updates",
              "docs/troubleshoot",
              "docs/faq"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "docs/rashin",
              "docs/security"
            ]
          }
        ]
      },
      {
        "tab": "Contribute",
        "groups": [
          {
            "group": "Project",
            "pages": [
              "docs/vision",
              "docs/omarchy-heritage",
              "docs/maintenance"
            ]
          },
          {
            "group": "Build & release",
            "pages": [
              "docs/iso-build-recipe",
              "docs/release-pipeline"
            ]
          },
          {
            "group": "Internals",
            "pages": [
              "docs/ui-patterns",
              "docs/customization-inventory",
              "docs/branding"
            ]
          }
        ]
      }
    ]
  }
}

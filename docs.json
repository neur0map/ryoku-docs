{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ryoku",
  "colors": {
    "primary": "#e2342a",
    "light": "#ef5b50",
    "dark": "#e2342a"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Fraunces"
    },
    "body": {
      "family": "Space Grotesk"
    }
  },
  "background": {
    "color": {
      "dark": "#100d08"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "favicon": "/assets/brand/logo.svg",
  "logo": {
    "light": "/assets/brand/light.png",
    "dark": "/assets/brand/dark.png"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.ryoku.dev"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/neur0map/ryoku-arch"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/neur0map/ryoku-arch",
      "website": "https://ryoku.dev"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Use Ryoku",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Get started",
            "pages": [
              "docs/install",
              "docs/first-boot",
              "docs/tour"
            ]
          },
          {
            "group": "Daily use",
            "pages": [
              "docs/keybindings",
              "docs/updates"
            ]
          },
          {
            "group": "Plugins",
            "pages": [
              "docs/plugins"
            ]
          },
          {
            "group": "Customize",
            "pages": [
              "docs/customize"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "docs/troubleshoot"
            ]
          }
        ]
      },
      {
        "tab": "Contribute",
        "groups": [
          {
            "group": "Project",
            "pages": [
              "docs/vision",
              "docs/omarchy-heritage",
              "docs/maintenance"
            ]
          },
          {
            "group": "Build & release",
            "pages": [
              "docs/iso-build-recipe",
              "docs/release-pipeline"
            ]
          },
          {
            "group": "Internals",
            "pages": [
              "docs/ui-patterns",
              "docs/customization-inventory",
              "docs/branding"
            ]
          }
        ]
      }
    ]
  }
}
